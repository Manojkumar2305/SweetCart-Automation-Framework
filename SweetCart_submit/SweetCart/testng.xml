<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SweetCart – Sweet Shop Automation Suite
  Run with: mvn test
  parallel="methods" + thread-count="2" satisfies Good-to-Have requirement.
-->
<suite name="SweetCart – Sweet Shop Suite"
       verbose="1"
       thread-count="2"
       parallel="methods">

    <!-- Screenshot on failure + ExtentReports HTML -->
    <listeners>
        <listener class-name="com.sweetcart.listeners.TestListener"/>
    </listeners>

    <!-- Module 1: User Authentication -->
    <test name="Auth Tests">
        <classes>
            <class name="com.sweetcart.tests.AuthTest">
                <methods>
                    <include name="testLoginScenarios"/>
                    <include name="testLogout"/>
                    <include name="testAccountWithoutLogin"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- Module 2: Product Browse -->
    <test name="Product Browse Tests">
        <classes>
            <class name="com.sweetcart.tests.ProductBrowseTest">
                <methods>
                    <include name="testSweetsListingShowsProducts"/>
                    <include name="testCategoryFilterShowsProducts"/>
                    <include name="testProductDetailPageShowsInfo"/>
                    <include name="testAddToBasketButtonOnDetailPage"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- Module 3: Shopping Basket -->
    <test name="Basket Tests">
        <classes>
            <class name="com.sweetcart.tests.BasketTest">
                <methods>
                    <include name="testAddProductUpdatesNavCount"/>
                    <include name="testBasketShowsProductDetails"/>
                    <include name="testRemoveProductFromBasket"/>
                    <include name="testAddMultipleProductsToBasket"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- Module 4: Account and Order History -->
    <test name="Account Tests">
        <classes>
            <class name="com.sweetcart.tests.AccountTest">
                <methods>
                    <include name="testAccountShowsUserName"/>
                    <include name="testOrderHistoryPresent"/>
                    <include name="testOrderHistoryRowsHaveDateAndTotal"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- Module 5: Navigation and Static Content -->
    <test name="Navigation Tests">
        <classes>
            <class name="com.sweetcart.tests.NavigationTest">
                <methods>
                    <include name="testTopNavLinksPresent"/>
                    <include name="testAboutPageHeading"/>
                    <include name="testFooterPresent"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
